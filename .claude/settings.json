{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npx prisma generate)",
      "Bash(npx prisma migrate dev:*)",
      "Bash(npx prisma migrate deploy)",
      "Bash(npx prisma db push)",
      "Bash(npx prisma studio)",
      "Bash(npx prisma format)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(node -v)",
      "Bash(npm -v)"
    ],
    "deny": [
      "Bash(npx prisma migrate reset:*)",
      "Bash(rm -rf data)",
      "Bash(rm -rf data/psychhub.db)",
      "Bash(rm -rf prisma/migrations)",
      "Bash(rm -rf Sauvegarde)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)"
    ]
  },
  "env": {
    "NODE_OPTIONS": "--no-warnings"
  }
}
